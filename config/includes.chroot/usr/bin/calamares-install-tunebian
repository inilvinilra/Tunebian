#!/bin/sh
set -eu

export QT_AUTO_SCREEN_SCALE_FACTOR=1

if [ "$(id -u)" -ne 0 ]; then
    xhost +si:localuser:root >/dev/null 2>&1 || true
    exec sudo -n env \
        DISPLAY="${DISPLAY:-:0}" \
        XAUTHORITY="${XAUTHORITY:-}" \
        DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-}" \
        QT_AUTO_SCREEN_SCALE_FACTOR="${QT_AUTO_SCREEN_SCALE_FACTOR}" \
        /usr/bin/calamares-install-tunebian
fi

status=0

if [ -f /etc/fstab ] && [ ! -f /etc/fstab.orig.calamares ]; then
    mv /etc/fstab /etc/fstab.orig.calamares
fi

calamares || status=$?

if [ -f /etc/fstab.orig.calamares ]; then
    mv /etc/fstab.orig.calamares /etc/fstab
fi

exit "$status"
